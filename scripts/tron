#!/bin/bash
# tron - CLI for workspace development and contributor service tooling
#
# Usage: tron <command> [options]
#
# Development:
#   dev             Start dev server (dev-server profile, -b build, -t test, -d background)
#   ci              Run CI checks (fmt, check, clippy, test, bench, doc)
#   bench           Performance benchmarks (run, bless, compare)
#   version         Print/check/sync centralized release version mirrors
#   setup           First-time project setup
#
# Service:
#   start/stop/restart  Manage launchd service
#   status              Show service status
#
# Contributor service:
#   deploy          Build, test, deploy (--force to skip confirmations)
#   install         Contributor launchd setup (not used by the Mac app)
#   rollback        Restore previous binary (--yes to skip confirmation)
#   uninstall       Remove service and reset Mac onboarding (optionally reset settings/auth)
#   auto-deploy     Contributor auto-deploy watcher (install|uninstall|status|pause|resume|logs)
#
# Auth:
#   login           Authenticate with a provider (--label for multi-account)
#
# Logs:
#   logs            Query database logs (use -h for options)
#   errors          Show recent errors

set -e

#=============================================================================
# WORKSPACE RESOLUTION
#=============================================================================

# Resolve symlinks to get the real script location
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

# Ensure Rust toolchain commands are available even in non-interactive shells.
if ! command -v cargo >/dev/null 2>&1 && [ -x "$HOME/.cargo/bin/cargo" ]; then
    export PATH="$HOME/.cargo/bin:$PATH"
fi

#=============================================================================
# SHARED LIBRARY
#=============================================================================

source "$SCRIPT_DIR/tron-lib.sh"

#=============================================================================
# WORKSPACE-ONLY CONFIGURATION
#=============================================================================

# Rust workspace
RUST_WORKSPACE="$PROJECT_DIR/packages/agent"
RELEASE_BINARY="$RUST_WORKSPACE/target/release/tron"
DEV_SERVER_BINARY="$RUST_WORKSPACE/target/dev-server/tron"
BENCH_SCRIPT="$SCRIPT_DIR/benchmarks/bench.py"
BENCH_BASELINE_DIR="$SCRIPT_DIR/benchmarks/baselines"
BENCH_GATE_ITERATIONS=50
BENCH_GATE_MAX_P95_REGRESSION_PCT=15
BENCH_GATE_MAX_MEAN_REGRESSION_PCT=35

#=============================================================================
# COMMAND MODULES
#=============================================================================

for tron_cmd_module in "$SCRIPT_DIR"/tron.d/*.sh; do
    [ -e "$tron_cmd_module" ] && source "$tron_cmd_module"
done
unset tron_cmd_module

#=============================================================================
# HELP
#=============================================================================

cmd_help() {
    echo ""
    echo -e "${CYAN}Tron - Persistent AI Coding Agent${NC}"
    echo ""
    echo "Usage: tron <command> [options]"
    echo ""
    echo -e "${BOLD}Development (workspace only):${NC}"
    echo "  dev             Start server (dev-server profile; -b build, -t test, -d background)"
    echo "  ci              Run CI checks (fmt, check, clippy, test, bench, doc)"
    echo "  bench           Performance benchmarks (run, bless, compare)"
    echo "  version         Print/check/sync centralized release version mirrors"
    echo "  setup           First-time project setup"
    echo ""
    echo -e "${BOLD}Deployment (workspace only):${NC}"
    echo "  preflight       Pre-deploy infrastructure check"
    echo "  deploy          Build, test, deploy (--force, --ci for non-interactive)"
    echo "  install         Initial setup (launchd + CLI)"
    echo "  uninstall       Remove service and reset Mac onboarding (add --reset-settings and/or --reset-credentials)"
    echo "  auto-deploy     Contributor auto-deploy watcher (install|uninstall|status|pause|resume|logs)"
    echo ""
    echo -e "${BOLD}Runtime:${NC}"
    echo "  start           Start launchd service"
    echo "  stop            Stop service"
    echo "  restart         Restart service"
    echo "  status          Show service status"
    echo "  rollback        Restore previous binary (--yes to skip confirmation)"
    echo "  login           Authenticate with a provider (--label <name> for multi-account)"
    echo "  auth rotate     Rotate the WebSocket bearer token (forces iOS re-pair)"
    echo "  logs            Query database logs (use -h for options)"
    echo "  errors          Show recent errors"
    echo ""
    echo -e "${BOLD}Build profiles:${NC}"
    echo "  cargo check                        # Fast correctness check (no binary)"
    echo "  cargo build --profile dev-server   # Dev server (thin LTO, fast)"
    echo "  cargo build --release              # Production (fat LTO, comprehensive)"
    echo ""
}

#=============================================================================
# MAIN DISPATCH
#=============================================================================

case "${1:-help}" in
    help|--help|-h) cmd_help; exit 0 ;;
esac

ensure_tron_home

case "$1" in
    dev)       shift; cmd_dev "$@" ;;
    ci)        shift; cmd_ci "$@" ;;
    bench)     shift; cmd_bench "$@" ;;
    version)   shift; "$SCRIPT_DIR/tron-version" "$@" ;;
    preflight) cmd_preflight ;;
    deploy)    shift; cmd_deploy "$@" ;;
    install)   shift; cmd_install "$@" ;;
    rollback)  shift; cmd_rollback "$@" ;;
    setup)     shift; cmd_setup "$@" ;;
    status)    shift; cmd_status "$@" ;;
    start)     cmd_start ;;
    stop)      cmd_stop ;;
    restart)   cmd_restart ;;
    logs)      shift; query_logs "$@" ;;
    errors)    cmd_errors ;;
    login)     shift; cmd_login "$@" ;;
    auth)      shift; cmd_auth "$@" ;;
    uninstall) shift; cmd_uninstall "$@" ;;
    auto-deploy) shift; cmd_auto_deploy "$@" ;;
    *) print_error "Unknown command: $1"; cmd_help; exit 1 ;;
esac
