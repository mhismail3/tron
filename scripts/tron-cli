#!/usr/bin/env bash
# tron-cli - Universal CLI entrypoint for Tron server management
#
# Installed to ~/.tron/system/deployment/tron-cli
# Symlinked from ~/.local/bin/tron
#
# Handles runtime commands directly (status, start, stop, logs, etc.)
# Delegates workspace commands (dev, deploy, ci, etc.) to the workspace script.

set -e

# Resolve symlinks to get the real script location
_SOURCE="${BASH_SOURCE[0]}"
while [ -L "$_SOURCE" ]; do
    _DIR="$(cd -P "$(dirname "$_SOURCE")" && pwd)"
    _SOURCE="$(readlink "$_SOURCE")"
    [[ $_SOURCE != /* ]] && _SOURCE="$_DIR/$_SOURCE"
done
LIB_DIR="$(cd -P "$(dirname "$_SOURCE")" && pwd)"

# Source shared library (always lives alongside this script)
source "$LIB_DIR/tron-lib.sh"

# Workspace path (recorded by tron install/deploy)
_WORKSPACE_PATH=""
if [ -f "$DEPLOY_DIR/workspace-path" ]; then
    _WORKSPACE_PATH=$(cat "$DEPLOY_DIR/workspace-path")
fi

delegate_to_workspace() {
    local ws_script="${_WORKSPACE_PATH}/scripts/tron"
    if [ -n "$_WORKSPACE_PATH" ] && [ -f "$ws_script" ]; then
        exec "$ws_script" "$@"
    fi
    print_error "Dev commands require a workspace checkout."
    if [ -n "$_WORKSPACE_PATH" ]; then
        echo "  Expected at: $_WORKSPACE_PATH (not found)"
    fi
    echo "  Clone the repo and run: ./scripts/tron install"
    exit 1
}

cmd_help() {
    echo ""
    echo -e "${CYAN}Tron - Persistent AI Coding Agent${NC}"
    echo ""
    echo "Usage: tron <command> [options]"
    echo ""
    echo -e "${BOLD}Runtime:${NC}"
    echo "  status          Show service status"
    echo "  start           Start launchd service"
    echo "  stop            Stop service"
    echo "  restart         Restart service"
    echo "  rollback        Restore previous binary (--yes to skip confirmation)"
    echo "  login           Authenticate with Claude (--label <name> for multi-account)"
    echo "  logs            Query database logs (use -h for options)"
    echo "  errors          Show recent errors"
    echo ""
    if [ -n "$_WORKSPACE_PATH" ] && [ -d "$_WORKSPACE_PATH" ]; then
        echo -e "${BOLD}Development (via workspace):${NC}"
        echo "  dev             Start server (-b build, -t test, -d background)"
        echo "  deploy          Build, test, deploy (--force, --ci for non-interactive)"
        echo "  ci              Run CI checks (fmt, check, clippy, test, doc)"
        echo "  bench           Performance benchmarks (run, bless, compare)"
        echo "  setup           First-time project setup"
        echo "  install         Initial setup (launchd + CLI)"
        echo "  uninstall       Remove service (preserves data)"
        echo "  auto-deploy     Remote auto-deploy watcher"
        echo ""
    else
        echo -e "${DIM}Dev commands available when workspace is installed.${NC}"
        echo ""
    fi
}

case "${1:-help}" in
    help|--help|-h) cmd_help; exit 0 ;;
esac

ensure_tron_home

case "$1" in
    # Runtime (handled directly)
    status)          cmd_status ;;
    start)           cmd_start ;;
    stop)            cmd_stop ;;
    restart)         cmd_restart ;;
    logs)            shift; query_logs "$@" ;;
    errors)          cmd_errors ;;
    rollback)        shift; cmd_rollback "$@" ;;
    login)           shift; cmd_login "$@" ;;
    # Dev (delegate to workspace)
    dev|deploy|ci|bench|preflight|setup|install|uninstall|auto-deploy)
        delegate_to_workspace "$@" ;;
    *)
        print_error "Unknown command: $1"
        cmd_help
        exit 1
        ;;
esac
