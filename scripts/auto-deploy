#!/bin/bash
# Auto-deploy watcher — polls origin/main and deploys server changes.
# Designed to be run by launchd every 60 seconds.

set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Contributor-only guard:
#
# `tron auto-deploy` is the contributor workflow — it pulls from `origin/main`,
# rebuilds from source, and runs `tron deploy --force`. It REQUIRES a cloned
# git repository. End-users who installed Tron via the DMG have no repo and
# should use the user-mode `tron self-update` updater instead (plan §H.2).
#
# This guard refuses to run if we're not inside a git worktree so that the
# script fails fast and loudly rather than silently doing nothing or — worse —
# getting half-way into `git fetch` before bailing.
if ! (cd "$REPO_DIR" && git rev-parse --show-toplevel) >/dev/null 2>&1; then
    echo "[auto-deploy] ERROR: $REPO_DIR is not a git repository." >&2
    echo "[auto-deploy] The contributor auto-deploy flow requires a cloned repo." >&2
    echo "[auto-deploy] If you installed Tron via the DMG, use the user updater instead:" >&2
    echo "[auto-deploy]   tron self-update status" >&2
    echo "[auto-deploy]   tron self-update check" >&2
    echo "[auto-deploy] Uninstall this watcher with: tron auto-deploy uninstall" >&2
    exit 2
fi

# Source shared library for TRON_HOME and path config
source "$(dirname "$0")/tron-lib.sh"

# Auto-deploy specific paths
LOG_FILE="$DEPLOY_DIR/auto-deploy.log"
PAUSE_FILE="$TRON_HOME/auto-deploy.pause"
LOCK_FILE="$TRON_HOME/auto-deploy.lock"
DEPLOY_LOCK="$TRON_HOME/deploy.lock"
BRANCH="main"

# Server code paths that trigger a deploy
SERVER_PATHS="^packages/agent/|^scripts/"

log() { echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] $*" >> "$LOG_FILE"; }

cleanup() { rm -f "$LOCK_FILE"; }
trap cleanup EXIT

# --- Guards ---

# Pause file check
if [ -f "$PAUSE_FILE" ]; then
    exit 0
fi

# Prevent concurrent runs (stale lock protection with PID check)
if [ -f "$LOCK_FILE" ]; then
    existing_pid=$(cat "$LOCK_FILE" 2>/dev/null || true)
    if [ -n "$existing_pid" ] && kill -0 "$existing_pid" 2>/dev/null; then
        exit 0
    fi
    log "WARN: Stale lock file (PID $existing_pid dead), removing"
    rm -f "$LOCK_FILE"
fi
echo $$ > "$LOCK_FILE"

# Don't interfere with a manual deploy in progress
if [ -f "$DEPLOY_LOCK" ]; then
    log "SKIP: Manual deploy in progress (deploy.lock exists)"
    exit 0
fi

# Don't deploy if dev server has taken over
if lsof -t -i :9847 -sTCP:LISTEN >/dev/null 2>&1; then
    if ! launchd_is_loaded "com.tron.server"; then
        log "SKIP: Dev server active on port 9847"
        exit 0
    fi
fi

# --- Main logic ---

cd "$REPO_DIR"

# Ensure clean working tree (should always be clean on the home machine)
if ! git diff --quiet 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then
    log "WARN: Dirty working tree, skipping pull"
    exit 0
fi

# Fetch latest
if ! git fetch origin "$BRANCH" 2>>"$LOG_FILE"; then
    log "ERROR: git fetch failed"
    exit 1
fi

LOCAL=$(git rev-parse "$BRANCH")
REMOTE=$(git rev-parse "origin/$BRANCH")

# Nothing new
if [ "$LOCAL" = "$REMOTE" ]; then
    exit 0
fi

log "New commits: ${LOCAL:0:8} -> ${REMOTE:0:8}"

# Determine what changed
CHANGED_FILES=$(git diff --name-only "$LOCAL" "$REMOTE")

# Pull (fast-forward only to avoid conflicts)
if ! git merge --ff-only "origin/$BRANCH" 2>>"$LOG_FILE"; then
    log "ERROR: Fast-forward merge failed — local branch has diverged"
    log "ACTION REQUIRED: Manually resolve on home machine"
    exit 1
fi

log "Pulled to $(git rev-parse --short HEAD)"

# Check if any server paths changed
if echo "$CHANGED_FILES" | grep -qE "$SERVER_PATHS"; then
    log "Server code changed, starting deploy..."
    log "Changed server files:"
    echo "$CHANGED_FILES" | grep -E "$SERVER_PATHS" | while read -r f; do log "  $f"; done

    # Run the real deploy — full safety pipeline
    if "$REPO_DIR/scripts/tron" deploy --force 2>&1 | tee -a "$LOG_FILE"; then
        log "Deploy SUCCEEDED"
    else
        log "Deploy FAILED (exit $?) — tron deploy handles its own rollback"
    fi
else
    log "No server code changes (iOS/docs only), skipped deploy"
fi
