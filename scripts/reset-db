#!/bin/bash
#
# reset-db — Clear session/event/log data from the database.
#
# Usage: scripts/reset-db
#
# Stops the tron server, clears all session/event/log/task data from
# log.db, vacuums, and restarts the server.

set -euo pipefail

# Source shared library for paths
source "$(dirname "$0")/tron-lib.sh"

DB_DIR="$TRON_HOME/system/database"

# Tables to clear — everything except schema_version
DATA_TABLES=(
  sessions events logs blobs
  workspaces branches projects areas
  device_tokens
  tasks task_activity task_backlog task_dependencies
)

# FTS tables to rebuild (content is deleted via triggers or manually)
FTS_TABLES=(events_fts tasks_fts areas_fts)

usage() {
  echo "Usage: $(basename "$0")"
  echo ""
  echo "Clears session/event/log data from log.db."
  echo "Stops the server, clears data, vacuums, and restarts."
  exit 0
}

stop_server() {
  if service_is_running; then
    echo "Stopping tron server..."
    launchd_stop "$PLIST_NAME"
    sleep 1
  fi
}

start_server() {
  if [ -f "$PLIST_PATH" ]; then
    echo "Starting tron server..."
    launchd_start "$PLIST_NAME"
  else
    echo "Warning: $PLIST_PATH not found — server not started"
  fi
}

reset_database() {
  local db_path="$1"
  local db_name
  db_name=$(basename "$db_path" .db)

  if [ ! -f "$db_path" ]; then
    echo "  $db_name: not found, skipping"
    return
  fi

  echo "  $db_name: clearing data..."

  # Build SQL to delete from all data tables (order matters for FK constraints)
  local sql="PRAGMA foreign_keys = OFF;"

  # Delete from FTS tables first (rebuild command empties them cleanly)
  for fts in "${FTS_TABLES[@]}"; do
    sql+="DELETE FROM ${fts} WHERE 1=1;"
  done

  # Delete from data tables (children before parents)
  for table in "${DATA_TABLES[@]}"; do
    sql+="DELETE FROM ${table};"
  done

  sql+="PRAGMA foreign_keys = ON;"

  sqlite3 "$db_path" "$sql"

  echo "  $db_name: cleared."

  # Vacuum to reclaim space
  echo "  $db_name: vacuuming..."
  sqlite3 "$db_path" "VACUUM;"
  local size
  size=$(du -h "$db_path" | cut -f1)
  echo "  $db_name: done ($size)"
}

# Parse arguments
if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
fi

db_path="$DB_DIR/log.db"

# Confirm
echo "This will DELETE all sessions, events, logs, tasks from log.db"
read -rp "Continue? [y/N] " confirm
if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
  echo "Aborted."
  exit 0
fi

was_running=false
if service_is_running; then
  was_running=true
  stop_server
fi

echo "Resetting database..."
reset_database "$db_path"

if $was_running; then
  start_server
fi

echo "Done."
