#!/bin/bash
#
# reset-db — Clear session/event/log data from the database.
#
# Usage: scripts/reset-db
#
# Stops the tron server, clears primitive session/event/log/trace data
# from tron.sqlite, vacuums, and restarts the server.

set -euo pipefail

# Source shared library for paths
source "$(dirname "$0")/tron-lib.sh"

DB_DIR="$TRON_HOME/internal/database"

# Tables to clear — everything except schema_version.
DATA_TABLES=(
  trace_records logs events sessions blobs workspaces
)

usage() {
  echo "Usage: $(basename "$0")"
  echo ""
  echo "Clears session/event/log data from tron.sqlite."
  echo "Stops the server, clears data, vacuums, and restarts."
  exit 0
}

stop_server() {
  if service_is_running; then
    echo "Stopping tron server..."
    launchd_stop "$PLIST_NAME"
    sleep 1
  fi
}

start_server() {
  if [ -f "$PLIST_PATH" ]; then
    echo "Starting tron server..."
    launchd_start "$PLIST_NAME"
  else
    echo "Warning: $PLIST_PATH not found — server not started"
  fi
}

reset_database() {
  local db_path="$1"
  local db_name
  db_name=$(basename "$db_path" .db)

  if [ ! -f "$db_path" ]; then
    echo "  $db_name: not found, skipping"
    return
  fi

  echo "  $db_name: clearing data..."

  local sql="PRAGMA foreign_keys = OFF;"

  for table in "${DATA_TABLES[@]}"; do
    sql+="DELETE FROM ${table};"
  done

  sql+="PRAGMA foreign_keys = ON;"

  sqlite3 "$db_path" "$sql"

  echo "  $db_name: cleared."

  # Vacuum to reclaim space
  echo "  $db_name: vacuuming..."
  sqlite3 "$db_path" "VACUUM;"
  local size
  size=$(du -h "$db_path" | cut -f1)
  echo "  $db_name: done ($size)"
}

# Parse arguments
if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
fi

db_path="$DB_DIR/tron.sqlite"

# Confirm
echo "This will DELETE all sessions, events, logs, traces, and blobs from tron.sqlite"
read -rp "Continue? [y/N] " confirm
if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
  echo "Aborted."
  exit 0
fi

was_running=false
if service_is_running; then
  was_running=true
  stop_server
fi

echo "Resetting database..."
reset_database "$db_path"

if $was_running; then
  start_server
fi

echo "Done."
