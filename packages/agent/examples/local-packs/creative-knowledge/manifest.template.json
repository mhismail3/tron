{
  "packageId": "creative-knowledge-example",
  "version": "1.0.0",
  "manifestSchemaId": "tron.module.package_manifest.v1",
  "sourceProvenance": {
    "kind": "local_digest_pinned",
    "pathHint": "packages/agent/examples/local-packs/creative-knowledge"
  },
  "packageDigest": "__PACKAGE_DIGEST__",
  "trustTier": "local_digest_pinned",
  "signatureStatus": "unsigned_digest_pinned",
  "declaredWorkerKind": "local_process",
  "namespace": "creative_knowledge_example",
  "presentation": {
    "title": "Creative Knowledge Example Pack",
    "summary": "Prompt and notes transformation workflow with reusable generated UI review.",
    "category": "creative-knowledge",
    "modelPreset": "deep",
    "subagentRoles": ["research"],
    "generatedUiTarget": "package"
  },
  "declaredCapabilities": [
    {
      "functionId": "creative_knowledge_example::transform_prompt",
      "displayName": "Transform Prompt",
      "effectClass": "DeterministicCompute",
      "risk": "low",
      "requiredAuthority": ["creative_knowledge_example.read"],
      "outputResourceKinds": []
    },
    {
      "functionId": "creative_knowledge_example::notes_to_outline",
      "displayName": "Notes To Outline",
      "effectClass": "DeterministicCompute",
      "risk": "low",
      "requiredAuthority": ["creative_knowledge_example.read"],
      "outputResourceKinds": []
    },
    {
      "functionId": "creative_knowledge_example::save_transformation",
      "displayName": "Save Transformation",
      "effectClass": "IdempotentWrite",
      "risk": "medium",
      "requiredAuthority": ["creative_knowledge_example.write"],
      "idempotent": true,
      "outputResourceKinds": ["artifact"]
    }
  ],
  "requiredGrants": {
    "allowedCapabilities": [
      "creative_knowledge_example::transform_prompt",
      "creative_knowledge_example::notes_to_outline",
      "creative_knowledge_example::save_transformation"
    ],
    "allowedNamespaces": ["creative_knowledge_example"],
    "allowedAuthorityScopes": [
      "creative_knowledge_example.read",
      "creative_knowledge_example.write"
    ],
    "allowedResourceKinds": ["artifact"],
    "resourceSelectors": ["*"],
    "fileRoots": ["*"],
    "networkPolicy": "none",
    "maxRisk": "medium",
    "canDelegate": false,
    "approvalRequired": false
  },
  "configSchema": {
    "type": "object",
    "required": ["enabled", "defaultStyle", "saveTransformArtifacts"],
    "additionalProperties": false,
    "properties": {
      "enabled": {"type": "boolean", "default": true},
      "defaultStyle": {"type": "string", "default": "clear"},
      "saveTransformArtifacts": {"type": "boolean", "default": true}
    }
  },
  "declaredFiles": [
    {
      "resourceId": "__WORKER_RESOURCE_ID__",
      "versionId": "__WORKER_VERSION_ID__",
      "contentHash": "__WORKER_CONTENT_HASH__"
    },
    {
      "resourceId": "__RUNTIME_RESOURCE_ID__",
      "versionId": "__RUNTIME_VERSION_ID__",
      "contentHash": "__RUNTIME_CONTENT_HASH__"
    }
  ],
  "runtimeEntryPoint": {
    "kind": "local_process",
    "workerId": "creative-knowledge-example-worker",
    "commandTemplate": {
      "kind": "materialized_file",
      "resourceId": "__WORKER_RESOURCE_ID__",
      "versionId": "__WORKER_VERSION_ID__",
      "contentHash": "__WORKER_CONTENT_HASH__"
    },
    "argsTemplate": [],
    "workingDirectory": {
      "kind": "package_file_parent",
      "resourceId": "__WORKER_RESOURCE_ID__",
      "versionId": "__WORKER_VERSION_ID__"
    },
    "executableRefs": [
      {
        "resourceId": "__WORKER_RESOURCE_ID__",
        "versionId": "__WORKER_VERSION_ID__",
        "contentHash": "__WORKER_CONTENT_HASH__"
      },
      {
        "resourceId": "__RUNTIME_RESOURCE_ID__",
        "versionId": "__RUNTIME_VERSION_ID__",
        "contentHash": "__RUNTIME_CONTENT_HASH__"
      }
    ],
    "expectedFunctionIds": [
      "creative_knowledge_example::transform_prompt",
      "creative_knowledge_example::notes_to_outline",
      "creative_knowledge_example::save_transformation"
    ],
    "environmentPolicy": {"mode": "empty"},
    "visibility": "workspace",
    "timeoutMs": 10000
  },
  "healthPolicy": {"mode": "catalog_registered"},
  "sandboxProcessPolicy": {"networkPolicy": "none", "fileRoots": ["*"]},
  "redactionPolicy": {"mode": "redacted"}
}
