{
  "packageId": "tron-maintainer-example",
  "version": "1.0.0",
  "manifestSchemaId": "tron.module.package_manifest.v1",
  "sourceProvenance": {
    "kind": "local_digest_pinned",
    "pathHint": "packages/agent/examples/local-packs/tron-maintainer"
  },
  "packageDigest": "__PACKAGE_DIGEST__",
  "trustTier": "local_digest_pinned",
  "signatureStatus": "unsigned_digest_pinned",
  "declaredWorkerKind": "local_process",
  "namespace": "tron_maintainer_example",
  "presentation": {
    "title": "Tron Maintainer Example Pack",
    "summary": "Repo health, test summary, and scorecard/evidence helpers for local Tron maintenance.",
    "category": "tron-maintainer",
    "modelPreset": "balanced",
    "subagentRoles": ["review"],
    "generatedUiTarget": "package"
  },
  "declaredCapabilities": [
    {
      "functionId": "tron_maintainer_example::repo_health",
      "displayName": "Repo Health",
      "effectClass": "PureRead",
      "risk": "low",
      "requiredAuthority": ["tron_maintainer_example.read"],
      "outputResourceKinds": []
    },
    {
      "functionId": "tron_maintainer_example::test_summary",
      "displayName": "Test Summary",
      "effectClass": "DeterministicCompute",
      "risk": "low",
      "requiredAuthority": ["tron_maintainer_example.read"],
      "outputResourceKinds": []
    },
    {
      "functionId": "tron_maintainer_example::scorecard_evidence",
      "displayName": "Scorecard Evidence",
      "effectClass": "IdempotentWrite",
      "risk": "medium",
      "requiredAuthority": ["tron_maintainer_example.write"],
      "idempotent": true,
      "outputResourceKinds": ["artifact"]
    }
  ],
  "requiredGrants": {
    "allowedCapabilities": [
      "tron_maintainer_example::repo_health",
      "tron_maintainer_example::test_summary",
      "tron_maintainer_example::scorecard_evidence"
    ],
    "allowedNamespaces": ["tron_maintainer_example"],
    "allowedAuthorityScopes": [
      "tron_maintainer_example.read",
      "tron_maintainer_example.write"
    ],
    "allowedResourceKinds": ["artifact"],
    "resourceSelectors": ["*"],
    "fileRoots": ["*"],
    "networkPolicy": "none",
    "maxRisk": "medium",
    "canDelegate": false,
    "approvalRequired": false
  },
  "configSchema": {
    "type": "object",
    "required": ["enabled", "repoPath", "scorecardPath", "evidencePath"],
    "additionalProperties": false,
    "properties": {
      "enabled": {"type": "boolean", "default": true},
      "repoPath": {"type": "string", "default": "."},
      "scorecardPath": {"type": "string", "default": "packages/agent/docs/tron-productization-scorecard.md"},
      "evidencePath": {"type": "string", "default": "packages/agent/docs/tron-productization-evidence-manifest.md"}
    }
  },
  "declaredFiles": [
    {
      "resourceId": "__WORKER_RESOURCE_ID__",
      "versionId": "__WORKER_VERSION_ID__",
      "contentHash": "__WORKER_CONTENT_HASH__"
    },
    {
      "resourceId": "__RUNTIME_RESOURCE_ID__",
      "versionId": "__RUNTIME_VERSION_ID__",
      "contentHash": "__RUNTIME_CONTENT_HASH__"
    }
  ],
  "runtimeEntryPoint": {
    "kind": "local_process",
    "workerId": "tron-maintainer-example-worker",
    "commandTemplate": {
      "kind": "materialized_file",
      "resourceId": "__WORKER_RESOURCE_ID__",
      "versionId": "__WORKER_VERSION_ID__",
      "contentHash": "__WORKER_CONTENT_HASH__"
    },
    "argsTemplate": [],
    "workingDirectory": {
      "kind": "package_file_parent",
      "resourceId": "__WORKER_RESOURCE_ID__",
      "versionId": "__WORKER_VERSION_ID__"
    },
    "executableRefs": [
      {
        "resourceId": "__WORKER_RESOURCE_ID__",
        "versionId": "__WORKER_VERSION_ID__",
        "contentHash": "__WORKER_CONTENT_HASH__"
      },
      {
        "resourceId": "__RUNTIME_RESOURCE_ID__",
        "versionId": "__RUNTIME_VERSION_ID__",
        "contentHash": "__RUNTIME_CONTENT_HASH__"
      }
    ],
    "expectedFunctionIds": [
      "tron_maintainer_example::repo_health",
      "tron_maintainer_example::test_summary",
      "tron_maintainer_example::scorecard_evidence"
    ],
    "environmentPolicy": {"mode": "empty"},
    "visibility": "workspace",
    "timeoutMs": 10000
  },
  "healthPolicy": {"mode": "catalog_registered"},
  "sandboxProcessPolicy": {"networkPolicy": "none", "fileRoots": ["*"]},
  "redactionPolicy": {"mode": "redacted"}
}
