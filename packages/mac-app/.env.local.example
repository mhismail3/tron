# Copy to .env.local for local Xcode/debug builds that need real push delivery.
# The real .env.local file is gitignored and must not be committed.
TRON_RELAY_URL=https://tron-push-relay.example.workers.dev
TRON_RELAY_SECRET=replace-with-the-cloudflare-worker-hmac-secret
TRON_RELAY_ENVIRONMENT=production
